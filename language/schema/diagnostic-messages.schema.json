{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MyDefrag diagnostic message definitions",
  "type": "object",
  "required": [
    "diagnostics"
  ],
  "properties": {
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "code",
          "component",
          "severity",
          "messageKey",
          "status"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "component": {
            "type": "string"
          },
          "severity": {
            "enum": [
              "error",
              "warning",
              "information",
              "hint"
            ]
          },
          "messageKey": {
            "type": "string"
          },
          "placeholders": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "source": {
            "type": "string"
          },
          "status": {
            "$ref": "translation-status.schema.json#/definitions/reviewState"
          }
        }
      }
    }
  }
}
