{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MyDefrag message placeholders",
  "type": "object",
  "required": [
    "placeholders"
  ],
  "properties": {
    "placeholders": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "description"
        ],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
          },
          "description": {
            "type": "string"
          },
          "example": {
            "type": "string"
          }
        }
      }
    }
  }
}
