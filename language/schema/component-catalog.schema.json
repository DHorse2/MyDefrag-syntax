{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MyDefrag component catalog",
  "type": "object",
  "required": [
    "entries"
  ],
  "properties": {
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "key",
          "component",
          "category",
          "role",
          "text",
          "status"
        ],
        "properties": {
          "key": {
            "type": "string",
            "pattern": "^[a-z][A-Za-z0-9]*(\\.[A-Za-z0-9_-]+)+$"
          },
          "component": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "placeholders": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "status": {
            "$ref": "translation-status.schema.json#/definitions/reviewState"
          },
          "source": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
