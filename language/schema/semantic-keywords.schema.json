{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MyDefrag semantic keyword definitions",
  "type": "object",
  "required": [
    "keywords"
  ],
  "properties": {
    "keywords": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "canonical",
          "category",
          "parent",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "canonical": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "parent": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "status": {
            "$ref": "translation-status.schema.json#/definitions/reviewState"
          }
        }
      }
    }
  }
}
