{
    "name": "MyDefrag Script",
    "scopeName": "source.mydfrg",
    "fileTypes": [
        "MyDc",
        "MyD"
    ],
    "patterns": [
        {
            "include": "#setvariable"
        },
        {
            "include": "#macros"
        },
        {
            "include": "#preprocessor"
        },
        {
            "include": "#comments"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#constants"
        },
        {
            "include": "#volume_keywords"
        },
        {
            "include": "#file_keywords"
        },
        {
            "include": "#settings"
        },
        {
            "include": "#fileactions"
        },
        {
            "include": "#filebooleans"
        },
        {
            "include": "#variables"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#functions"
        }
    ],
    "repository": {
        "macros": {
            "patterns": [
                {
                    "name": "constant.other.macro.mydfrg",
                    "match": "!\\w+!"
                }
            ]
        },
        "preprocessor": {
            "patterns": [
                {
                    "name": "meta.preprocessor.include.mydfrg",
                    "match": "!include\\s+\"[^\"]*\"!",
                    "captures": {
                        "0": {
                            "name": "keyword.control.include.mydfrg"
                        }
                    }
                }
            ]
        },
        "setvariable": {
            "patterns": [
                {
                    "begin": "\\b(SetVariable)\\s*\\(\\s*",
                    "beginCaptures": {
                        "1": {
                            "name": "keyword.other.setting.mydfrg"
                        }
                    },
                    "end": "(?=[,)])",
                    "patterns": [
                        {
                            "name": "variable.other.mydfrg",
                            "match": "\\w+"
                        }
                    ]
                }
            ]
        },
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.number-sign.mydfrg",
                    "match": "^\\s*#.*$"
                },
                {
                    "name": "comment.block.mydfrg",
                    "begin": "/\\*",
                    "end": "\\*/"
                },
                {
                    "name": "comment.line.double-slash.mydfrg",
                    "begin": "//",
                    "end": "$"
                },
                {
                    "name": "comment.line.number-sign.preview.mydfrg",
                    "begin": "^(?:\\s*\\|\\s*\\d*\\s*)*\\s*#",
                    "end": "$",
                    "patterns": []
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.single.mydfrg",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "name": "meta.preprocessor.include.mydfrg",
                            "match": "!include\\s+\"[^\"]*\"!"
                        },
                        {
                            "name": "constant.other.macro.mydfrg",
                            "match": "!\\w+!"
                        }
                    ]
                },
                {
                    "name": "string.quoted.double.mydfrg",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "meta.preprocessor.include.mydfrg",
                            "match": "!include\\s+\"[^\"]*\"!"
                        },
                        {
                            "name": "constant.other.macro.mydfrg",
                            "match": "!\\w+!"
                        },
                        {
                            "name": "entity.name.function.shell.mydfrg",
                            "match": "[^\\\\/\"]+\\.(?:bat|cmd|exe|com)(?=\")",
                            "captures": {
                                "0": {
                                    "name": "entity.name.function.shell.mydfrg"
                                }
                            }
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.mydfrg",
                    "match": "\\b[0-9]+(\\.[0-9]+)?([KkMmGgTt]i?)?\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.mydfrg",
                    "match": "\\b(yes|no|all|SKIP|Ascending|Descending|Fast|WithShuffling|DoNotVacate|ChunkSize|now)\\b"
                }
            ]
        },
        "volume_keywords": {
            "patterns": [
                {
                    "name": "keyword.control.volume.mydfrg",
                    "match": "\\b(VolumeSelect|VolumeActions|VolumeEnd)\\b"
                }
            ]
        },
        "file_keywords": {
            "patterns": [
                {
                    "name": "keyword.control.file.mydfrg",
                    "match": "\\b(FileSelect|FileActions|FileEnd)\\b"
                }
            ]
        },
        "settings": {
            "patterns": [
                {
                    "name": "keyword.other.setting.mydfrg",
                    "match": "\\b(Title|Description|Slowdown|MaxRunTime|ExitIfTimeout|WriteLogfile|AppendLogfile|RunScript|RunProgram|SetStatisticsWindowText|ExcludeVolumes|WhenFinished|SetScreenSaver|SetScreenPowerSaver|PreventScreenSaving|PreventPowerSaving|DismountVolume|PlaceNtfsSystemFiles)\\b"
                }
            ]
        },
        "fileactions": {
            "patterns": [
                {
                    "name": "support.function.fileaction.mydfrg",
                    "match": "\\b(Defragment|FastDefrag|FastFill|FastFillWithShuffling|SortByName|SortBySize|SortByDate|SortByAccess|SortByCreation|SortByExtension|MoveToEndOfDisk|MoveUpToZone|AddGap|MakeGap|PlaceNtfsSystemFiles)\\b"
                }
            ]
        },
        "filebooleans": {
            "patterns": [
                {
                    "name": "support.function.fileboolean.mydfrg",
                    "match": "\\b(Name|Filename|Path|Extension|Directory|ReadOnly|Hidden|System|Archive|Compressed|Encrypted|Temporary|SparseFile|ReparsePoint|NotIndexed|Attribute|MinSize|MaxSize|MinFragments|MaxFragments|CreatedBefore|CreatedAfter|ModifiedBefore|ModifiedAfter|AccessedBefore|AccessedAfter|LastAccess|LastAccessEnabled|SelectNtfsSystemFiles|SelectBootOptimizeFiles|ImportListFromProgramHints|CommandlineVolumes|Remote|Removable|Writable|Mounted|Fixed|Network|CDRom|Ram)\\b"
                }
            ]
        },
        "variables": {
            "patterns": [
                {
                    "name": "variable.language.mydfrg",
                    "match": "\\b(VolumeSize|VolumeFree|VolumeUsed|MftSize|ZoneBegin|ZoneEnd|SystemFilesPosition)\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.logical.mydfrg",
                    "match": "\\b(and|or|not|AND|OR|NOT)\\b"
                },
                {
                    "name": "keyword.operator.arithmetic.mydfrg",
                    "match": "[+\\-*/]"
                },
                {
                    "name": "keyword.operator.comparison.mydfrg",
                    "match": "[<>=]"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "support.function.math.mydfrg",
                    "match": "\\b(RoundUp|RoundDown|Minimum|Maximum|Percentage)\\b"
                },
                {
                    "name": "keyword.other.time.mydfrg",
                    "match": "\\b(days?|hours?|minutes?|weeks?|months?|years?|ago)\\b"
                }
            ]
        }
    }
}