{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MyDefrag locale metadata",
  "type": "object",
  "required": [
    "locales"
  ],
  "properties": {
    "locales": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "englishName",
          "nativeName",
          "direction",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "englishName": {
            "type": "string"
          },
          "nativeName": {
            "type": "string"
          },
          "direction": {
            "enum": [
              "ltr",
              "rtl"
            ]
          },
          "status": {
            "$ref": "translation-status.schema.json#/definitions/reviewState"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
