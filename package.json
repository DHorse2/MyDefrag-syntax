{
    "name": "mydefrag-syntax",
    "displayName": "MyDefrag Script (.MyDc / .MyD)",
    "description": "Syntax highlighting for MyDefrag scripting language",
    "version": "0.2.0",
    "publisher": "macrodm",
    "repository": {
        "type": "git",
        "url": "https://github.com/DHorse2/MyDefrag-syntax"
    },
    "engines": {
        "vscode": "^1.82.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "contributes": {
        "configuration": {
            "title": "MyDefrag",
            "properties": {
                "mydfrg.exclude": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        "**/Backup/**",
                        "**/Bu/**",
                        "**/MdmSysTools/**",
                        "**/Archive/**",
                        "**/*.tmp.MyDc",
                        "**/Compile*",
                        "**/*.log",
                        "**/TaylorDoVs0_2/**",
                        "**/TaylorDoVs0_3/**",
                        "**/TaylorDoVs0_4/**",
                        "**/Log/**",
                        "**/Logs/**",
                        "**/artifacts/**",
                        "**/.user/**",
                        "**/node_modules/**",
                        "**/artifacts/**",
                        "**/resources/",
                        "**/dist/**",
                        "**/.git/**",
                        "**/.user/**",
                        "**/.vs/**",
                        "**/.vscode/**",
                        "**/Download/**",
                        "**/GithubIo/**"
                    ],
                    "description": "Glob patterns to exclude from MyDefrag validation"
                },
                "mydfrg.debugOn": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable MyDefrag extension debug logging."
                },
                "mydfrg.verboseLevel": {
                    "type": "number",
                    "default": 5,
                    "minimum": 0,
                    "maximum": 10,
                    "description": "MyDefrag extension verbosity level. Debug logging requires mydfrg.debugOn."
                },
                "mydfrg.referenceRelativePathLevel": {
                    "type": [
                        "number",
                        "string"
                    ],
                    "default": "Error",
                    "enum": [
                        0,
                        1,
                        2,
                        3,
                        4,
                        "None",
                        "Error",
                        "Warning",
                        "Information",
                        "Hint"
                    ],
                    "description": "Diagnostic severity for references found only by walking up parent folders."
                },
                "mydfrg.referenceContainsMacros": {
                    "type": [
                        "number",
                        "string"
                    ],
                    "default": 3,
                    "enum": [
                        0,
                        1,
                        2,
                        3,
                        4,
                        "None",
                        "Error",
                        "Warning",
                        "Information",
                        "Hint"
                    ],
                    "description": "Diagnostic severity for references containing execution-time macros."
                },
                "mydfrg.referenceFileFoundLevel": {
                    "type": [
                        "number",
                        "string"
                    ],
                    "default": 3,
                    "enum": [
                        0,
                        1,
                        2,
                        3,
                        4,
                        "None",
                        "Error",
                        "Warning",
                        "Information",
                        "Hint"
                    ],
                    "description": "Diagnostic severity for references whose target files are found."
                },
                "mydfrg.referenceFileNotFoundLevel": {
                    "type": [
                        "number",
                        "string"
                    ],
                    "default": 1,
                    "enum": [
                        0,
                        1,
                        2,
                        3,
                        4,
                        "None",
                        "Error",
                        "Warning",
                        "Information",
                        "Hint"
                    ],
                    "description": "Diagnostic severity for references whose target files are not found."
                },
                "mydfrg.fragmentParentLevel": {
                    "type": [
                        "number",
                        "string"
                    ],
                    "default": 3,
                    "enum": [
                        0,
                        1,
                        2,
                        3,
                        4,
                        "None",
                        "Error",
                        "Warning",
                        "Information",
                        "Hint"
                    ],
                    "description": "Diagnostic severity for inferred fragment parent messages."
                }
            }
        },
        "languages": [
            {
                "id": "mydfrg",
                "aliases": [
                    "MyDefrag Script",
                    "mydfrg"
                ],
                "extensions": [
                    ".MyDc",
                    ".MyD",
                    ".mydc",
                    ".myd",
                    ".MYDC",
                    ".MYD"
                ],
                "configuration": "./src/language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "mydfrg",
                "scopeName": "source.mydfrg",
                "path": "./src/syntaxes/mydfrg.tmLanguage.json"
            }
        ],
        "snippets": [
            {
                "language": "mydfrg",
                "path": "./snippets/mydfrg.code-snippets"
            }
        ],
        "commands": [
            {
                "command": "mydfrg.openPreview",
                "title": "Open Preview"
            },
            {
                "command": "mdm.openFileAtPosition",
                "title": "Open File at Position"
            },
            {
                "command": "mydfrg.openSettings",
                "title": "MyDefrag: Open Settings"
            }
        ],
        "menus": {
            "editor/title": [
                {
                    "command": "mydfrg.openPreview",
                    "when": "resourceExtname == .MyDc || resourceExtname == .MyD || resourceExtname == .mydc || resourceExtname == .myd || resourceExtname == .MYDC || resourceExtname == .MYD",
                    "group": "navigation"
                }
            ],
            "editor/title/context": [
                {
                    "command": "mydfrg.openPreview",
                    "when": "resourceExtname == .MyDc || resourceExtname == .MyD || resourceExtname == .mydc || resourceExtname == .myd || resourceExtname == .MYDC || resourceExtname == .MYD",
                    "group": "navigation"
                }
            ]
        },
        "links": [
            {
                "enablement": "true"
            }
        ]
    },
    "main": "./src/extension.js",
    "activationEvents": [
        "onLanguage:mydfrg",
        "onLanguage:bat",
        "onCommand:mydfrg.openPreview",
        "onCommand:mdm.openFileAtPosition",
        "onCommand:mydfrg.openSettings"
    ],
    "scripts": {
        "deploy:local": "powershell -ExecutionPolicy Bypass -File ./scripts/build-and-deploy.ps1",
        "liveUpdate:local": "powershell -ExecutionPolicy Bypass -File ./scripts/update-live-MyDefrag.ps1",
        "pack:vsix": "powershell -ExecutionPolicy Bypass -File ./scripts/pack-vsix.ps1",
        "publish:vsx": "powershell -ExecutionPolicy Bypass -File ./scripts/publish-vsx.ps1",
        "clean": "rimraf dist out .vscodeignore",
        "build": "echo 'no build step for pure Node.js extension'",
        "prepare": "npm run build",
        "enableNetwwork:local": "powershell -ExecutionPolicy Bypass -File ./scripts/enable-networkDrives.ps1",
        "listSymLinks:local": "powershell -ExecutionPolicy Bypass -File ./scripts/list-Win-SymLinks.ps1",
        "addVsCodiumToExplorer:local": "powershell -ExecutionPolicy Bypass -File ./scripts/add-VsCodium-ToExplorer.ps1"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1",
        "vscode-languageserver": "^9.0.1",
        "vscode-languageserver-textdocument": "^1.0.12"
    },
    "devDependencies": {
        "@vscode/vsce": "^3.9.2",
        "vsce": "^2.0.0",
        "rimraf": "^3.0.2"
    }
}
