{
    "name": "mydc",
    "displayName": "MyDefrag Script (.MyDc / .MyD)",
    "description": "Syntax highlighting for MyDefrag scripting language",
    "version": "0.1.0",
    "publisher": "local",
    "activationEvents": [
        "onLanguage:mydc"
    ],
    "engines": {
        "vscode": "^1.0.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "contributes": {
        "languages": [
            {
                "id": "mydc",
                "aliases": [
                    "MyDefrag Script",
                    "mydc"
                ],
                "extensions": [
                    ".MyDc",
                    ".MyD",
                    ".mydc",
                    ".myd"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "mydc",
                "scopeName": "source.mydc",
                "path": "./mydc.tmLanguage.json"
            }
        ],
        "commands": [
            {
                "command": "mydc.openPreview",
                "title": "Open Preview"
            },
            {
                "command": "mdm.openFileAtPosition",
                "title": "Open File at Position"
            }
        ],
        "menus": {
            "editor/title": [
                {
                    "command": "mydc.openPreview",
                    "when": "resourceExtname == .MyDc || resourceExtname == .MyD || resourceExtname == .mydc || resourceExtname == .myd",
                    "group": "navigation"
                }
            ],
            "editor/title/context": [
                {
                    "command": "mydc.openPreview",
                    "when": "resourceExtname == .MyDc || resourceExtname == .MyD || resourceExtname == .mydc || resourceExtname == .myd",
                    "group": "navigation"
                }
            ]
        },
        "links": [
            {
                "enablement": "true"
            }
        ]
    },
    "main": "./extension.js",
    "dependencies": {
        "vscode-languageclient": "^9.0.1",
        "vscode-languageserver": "^9.0.1",
        "vscode-languageserver-textdocument": "^1.0.12"
    },
    "devDependencies": {}
}