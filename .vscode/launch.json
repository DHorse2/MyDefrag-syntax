{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Extension",
            "type": "extensionHost",
            "request": "launch",
            "runtimeExecutable": "${execPath}",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}"
            ],
            "skipFiles": [
                "<node_internals>/**",
                "${env:USERPROFILE}/.vscode-oss/extensions/**",
                "**/node_modules/**"
            ]
        },
        {
            "name": "Attach to Language Server",
            "type": "node",
            "request": "attach",
            "port": 6009,
            "restart": true,
            "skipFiles": [
                "<node_internals>/**"
            ]
        }
    ],
    "compounds": [
        {
            "name": "Extension + Server",
            "configurations": [
                "Run Extension",
                "Attach to Language Server"
            ]
        }
    ]
}